# Скопіюй у .env і заповни значення
TELEGRAM_BOT_TOKEN=

# HTTP API (сервер)
PORT=3000
# URL бекенду для бота (локально)
SERVER_URL=http://localhost:3000

# Redis (дані користувачів бота)
# Локально без Docker: redis://127.0.0.1:6379
# У docker compose для бота підставляється redis://redis:6379 автоматично
REDIS_URL=redis://127.0.0.1:6379

# Автобекап даних користувачів (очок/ресурсів/досягнень) з Redis у локальний файл.
# Інтервал у мс, за замовчуванням 300000 (5 хв)
# REDIS_BACKUP_INTERVAL_MS=300000
# Куди писати бекап. За замовчуванням: ./data/redis-user-backup.json
# REDIS_BACKUP_FILE=./data/redis-user-backup.json

# Арки розвитку:
# Якщо вказано ARC_INTERVAL_MS, інтервал фіксований.
# ARC_INTERVAL_MS=43200000
# Якщо ARC_INTERVAL_MS не задано, береться випадковий інтервал у діапазоні нижче
# (кілька повідомлень за день у різний час).
# ARC_MIN_INTERVAL_MS=21600000
# ARC_MAX_INTERVAL_MS=50400000

# Опційно: твій числовий Telegram user id (дізнатись у @userinfobot).
# Дозволяє команду /grant_balance 500 — докинути промінчики після нового Redis на сервері.
# BOT_ADMIN_USER_IDS=123456789
